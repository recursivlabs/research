# Book-a-demo target for all CTAs (falls back to https://recursiv.io/demo)
NEXT_PUBLIC_DEMO_URL=https://recursiv.io/demo

# Live leaderboard dataset URL (public Recursiv storage object).
# When unset, the site serves the committed snapshot in data/leaderboard.json.
LEADERBOARD_DATA_URL=

# Server-side Recursiv API key (used by the experiment harness, not the site runtime).
RECURSIV_API_KEY=
NEXT_PUBLIC_RECURSIV_URL=https://api.recursiv.io
